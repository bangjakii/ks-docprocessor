# Salin file ini jadi .env lalu isi nilainya. JANGAN commit .env.
ANTHROPIC_API_KEY=sk-ant-isi-disini     # klasifikasi dokumen (process_docs / ingest --apply)
PINECONE_API_KEY=pcsk-isi-disini        # index_to_pinecone (integrated embedding, embed server-side)
# OPENAI_API_KEY tidak diperlukan lagi — Pinecone integrated embedding (multilingual-e5-large)
# yang meng-embed, bukan OpenAI. Isi hanya kalau kamu ganti ke provider OpenAI.

# Render PDF→gambar (WAJIB: poppler dipakai render scan + hitung halaman/pdfinfo).
# Tesseract WAJIB juga sekarang — mode default 'hybrid' pakai tesseract buat tulisan cetak.
POPPLER_PATH=C:\path\ke\poppler-26.02.0\Library\bin
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Baca scan di index_to_pinecone:
#   "hybrid" (DEFAULT) — Tesseract utk cetak (gratis), Vision utk tulisan tangan/stempel.
#   "vision"           — paksa Claude vision semua (mahal, paling bersih).
#   "tesseract"        — paksa tesseract semua (gratis, kotor di tulisan tangan).
# OCR_ENGINE=hybrid
# Default HEMAT: haiku utk vision normal, sonnet utk scan terjelek (conf rendah).
# VISION_MODEL=claude-haiku-4-5         # vision normal (escalation conf 55-75)
# VISION_MODEL_STRONG=claude-sonnet-4-6 # scan TERJELEK (conf <55) — naikkan ke opus utk kualitas maks
# Router hybrid (kalibrasi via calibrate_ocr.py kalau perlu):
# OCR_CONF_OK=75      # confidence tesseract >= ini & rapi → keep (gratis); di bawah → vision
# OCR_CONF_STRONG=55  # conf < ini → vision pakai VISION_MODEL_STRONG (bukan VISION_MODEL)
# OCR_MIN_INK=4       # kata < ini & low-conf → halaman dianggap drawing/blank
# Batas halaman OCR per file scan, PER DOC-TYPE (PDF digital tak terpengaruh):
# OCR_PAGE_CAP=5      # default; Legal/umum
# OCR_CAP_HIGH=12     # Finance/invoice/faktur/pinjaman (faktur sering nyempil di hal dalam)
# OCR_CAP_LOW=2       # Engineering/drawing/brosur (hal 2+ cuma gambar, low-value)
# Kualitas maks (lebih mahal): VISION_MODEL=claude-sonnet-4-6 VISION_MODEL_STRONG=claude-opus-4-8

# Ekstraksi field terstruktur (doc_number / expire_date / counterparty):
# regex gratis + LLM fallback tertarget (cuma field kosong & doc-type relevan).
# EXTRACT_FIELDS=1                 # set 0 utk matikan total
# EXTRACT_LLM=1                    # set 0 → regex saja (tanpa LLM)
# EXTRACT_MODEL=claude-haiku-4-5   # model LLM extraction (text-only, murah)

# Opsional: override folder hasil ingest yang dibaca indexer (default D:\Arsip_Rapih)
# INGEST_DEST=D:\Arsip_Rapih
